{
  "name": "english-learning-app",
  "version": "1.0.0",
  "description": "An English learning app focused on speaking and listening skills",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext js,jsx,ts,tsx",
    "typecheck": "tsc --noEmit",
    "test:c2": "npx tsx src/tests/c2-evaluation.ts",
    "test:c2-readiness": "npx tsx src/tests/c2-readiness-audit.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:update": "npx playwright test --update-snapshots",
    "generate-audio": "npx tsx scripts/generateAudio.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/generative-ai": "^0.24.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@typescript-eslint/eslint-plugin": "^5.53.0",
    "@typescript-eslint/parser": "^5.53.0",
    "@vitejs/plugin-react": "^3.1.0",
    "eslint": "^8.34.0",
    "typescript": "^4.9.4",
    "vite": "^4.1.0"
  }
}
